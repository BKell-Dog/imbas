<div class="contact-form" id="contact-form">
  <link rel="stylesheet" href="/css/contact.css">
  <label for="project">What are you building?</label>
  <textarea id="project" rows="3"></textarea>

  <div class="email-row flex-row gap-10">
    <div class="email-field flex-row">
      X &nbsp; <input type="email" id="email" class="email-input" placeholder="Your email" autocomplete="email">
    </div>
    <button class="submit-btn red-button">Send</button>
  </div>
  
  <div class="or">or</div>

  <div class="email-fallback flex-column">
    <span class="align-self-left">Write to our point of contact directly,</span>
    <a href="mailto:will@imbashardtech.com" class="align-self-center">will@imbashardtech.com</a>
    <span class="align-self-right">We read and respond to every email.</span>
  </div>
</div>