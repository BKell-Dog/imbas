<header class="flex-row justify-between">
	<link rel="stylesheet" href="/css/header.css">
	<div id="header-left" class="flex-row">
		<a href="/" class="header-logo">
			{% svg "awen.svg" %}
		</a>
		<a href="/" class="header-title">{{ site.title }}</a>
	</div>
	<div id="header-right" class="flex-row gap-10 align-center">
	{% for link in site.navLinks %}
		<a href="{{ link.url }}">{{ link.text }}</a>
	{% endfor %}
	</div>
</header>